# Azure App Service Linux (PHP 8.x uses nginx). Copy into place with azure/startup.sh
# (Startup Command: bash /home/site/wwwroot/azure/startup.sh).
# If the container layout differs, SSH: cp /etc/nginx/sites-enabled/default /home/site/default.bak
# and merge these rules into the active server { } block.

server {
    listen 8080;
    listen [::]:8080;
    root /home/site/wwwroot;
    index index.php index.html;
    server_name _;

    location = /favicon.ico {
        return 204;
        access_log off;
    }

    # Legacy flat URLs (301) — match .htaccess
    rewrite ^/login\.php$ /auth/login.php permanent;
    rewrite ^/register\.php$ /auth/register.php permanent;
    rewrite ^/verify-email\.php$ /auth/verify-email.php permanent;
    rewrite ^/logout\.php$ /auth/logout.php permanent;
    rewrite ^/account-settings\.php$ /account/settings.php permanent;
    rewrite ^/dashboard\.php$ /dashboard/index.php permanent;
    rewrite ^/my-orders\.php$ /orders/my-orders.php permanent;
    rewrite ^/order-history\.php$ /orders/order-history.php permanent;
    rewrite ^/create-order\.php$ /orders/create-order.php permanent;
    rewrite ^/checkout\.php$ /orders/checkout.php permanent;
    rewrite ^/invoice\.php$ /orders/invoice.php permanent;
    rewrite ^/catalog\.php$ /catalog/index.php permanent;
    rewrite ^/contact\.php$ /contact/index.php permanent;
    rewrite ^/calendar\.php$ /calendar/index.php permanent;
    rewrite ^/create-event\.php$ /calendar/create-event.php permanent;

    # PHP execution (matches Azure PHP 8 built-in image pattern)
    location ~ [^/]\.php(/|$) {
        fastcgi_split_path_info ^(.+?\.php)(/.*)$;
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        fastcgi_read_timeout 300;
    }

    location / {
        try_files $uri $uri/ @capstone_rewrite;
    }

    location @capstone_rewrite {
        rewrite ^/$ /public/pages/index.php last;
        rewrite ^/([A-Za-z0-9_\-/]+\.php)$ /public/pages/$1 last;
        return 404;
    }
}
