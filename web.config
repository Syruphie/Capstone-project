<?xml version="1.0" encoding="UTF-8"?>
<!-- IIS URL Rewrite (Azure App Service Windows + PHP). Mirrors root .htaccess. -->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="FaviconNoContent" stopProcessing="true">
          <match url="^favicon\.ico$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="204" statusReason="No Content" statusDescription="No Content" />
        </rule>
        <rule name="LegacyLogin" stopProcessing="true">
          <match url="^login\.php$" />
          <action type="Redirect" url="auth/login.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyRegister" stopProcessing="true">
          <match url="^register\.php$" />
          <action type="Redirect" url="auth/register.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyVerifyEmail" stopProcessing="true">
          <match url="^verify-email\.php$" />
          <action type="Redirect" url="auth/verify-email.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyLogout" stopProcessing="true">
          <match url="^logout\.php$" />
          <action type="Redirect" url="auth/logout.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyAccountSettings" stopProcessing="true">
          <match url="^account-settings\.php$" />
          <action type="Redirect" url="account/settings.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyDashboard" stopProcessing="true">
          <match url="^dashboard\.php$" />
          <action type="Redirect" url="dashboard/index.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyMyOrders" stopProcessing="true">
          <match url="^my-orders\.php$" />
          <action type="Redirect" url="orders/my-orders.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyOrderHistory" stopProcessing="true">
          <match url="^order-history\.php$" />
          <action type="Redirect" url="orders/order-history.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyCreateOrder" stopProcessing="true">
          <match url="^create-order\.php$" />
          <action type="Redirect" url="orders/create-order.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyCheckout" stopProcessing="true">
          <match url="^checkout\.php$" />
          <action type="Redirect" url="orders/checkout.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyInvoice" stopProcessing="true">
          <match url="^invoice\.php$" />
          <action type="Redirect" url="orders/invoice.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyCatalog" stopProcessing="true">
          <match url="^catalog\.php$" />
          <action type="Redirect" url="catalog/index.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyContact" stopProcessing="true">
          <match url="^contact\.php$" />
          <action type="Redirect" url="contact/index.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyCalendar" stopProcessing="true">
          <match url="^calendar\.php$" />
          <action type="Redirect" url="calendar/index.php" redirectType="Permanent" />
        </rule>
        <rule name="LegacyCreateEvent" stopProcessing="true">
          <match url="^create-event\.php$" />
          <action type="Redirect" url="calendar/create-event.php" redirectType="Permanent" />
        </rule>
        <rule name="ExistingFilesSkipRewrite" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>
        <rule name="RootToIndex" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="public/pages/index.php" />
        </rule>
        <rule name="RoutablePhpUnderPublicPages" stopProcessing="true">
          <match url="^([A-Za-z0-9_\-/]+\.php)$" />
          <action type="Rewrite" url="public/pages/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
