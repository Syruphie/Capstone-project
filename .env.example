# Copy to .env for local development. In Azure, use Application Settings (same names).

# Database (Azure Database for MySQL: use server FQDN as DB_HOST)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=globentech_db

APP_NAME=GlobenTech
BASE_URL=https://lab.globentech.com

# Mail — set MAIL_USE_SMTP=false only if PHP mail() relays (rare on Azure App Service)
MAIL_USE_SMTP=true
MAIL_SMTP_HOST=127.0.0.1
MAIL_SMTP_PORT=1025
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
# Leave empty for local/Mailhog; use tls (port 587) or ssl (465) for providers
MAIL_SMTP_ENCRYPTION=
SUPPORT_EMAIL=support@globentech.com

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret — live endpoint: https://YOUR_HOST/api.php?endpoint=payment-webhook
STRIPE_WEBHOOK_SECRET=
